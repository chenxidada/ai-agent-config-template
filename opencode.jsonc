{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  // 简化版插件 - 只注入系统提示，不拦截消息
  "plugin": ["./.opencode/plugins/kb-sync-runtime.mjs"],
  "mcp": {
    // ============================================
    // Knowledge Base MCP Server
    // ============================================
    // 
    // 连接模式（通过环境变量控制）：
    //   MCP_MODE=docker  - 使用 Docker 容器中的 MCP Server（推荐）
    //   MCP_MODE=local   - 使用本地源码运行 MCP Server
    //   MCP_MODE=auto    - 自动检测（默认）
    //
    // Docker 模式要求：
    //   1. knownbase 后端服务已通过 docker-compose 启动
    //   2. kb-mcp-server 容器正在运行
    //
    // 本地模式要求：
    //   1. 设置 KNOWNBASE_ROOT 环境变量指向 knownbase/AI-Chat 目录
    //   2. 已执行 pnpm build 构建 MCP Server
    //
    "knowledge-base": {
      "type": "local",
      "command": ["bash", "./knowledge-base-mcp.sh"],
      "environment": {
        "KB_API_URL": "http://localhost:4000/api/v1",
        "MCP_MODE": "auto"
      },
      "enabled": true
    },

    // ============================================
    // Playwright MCP Server — 浏览器访问能力
    // ============================================
    //
    // 文档: https://github.com/microsoft/playwright-mcp
    // 用途: 让 validator / implementer / reviewer 在前端验证、E2E 调试、
    //       UI 自检时调用结构化的 browser_* 工具集（约 25 个），
    //       例如 browser_navigate / browser_click / browser_snapshot /
    //       browser_take_screenshot / browser_console_messages /
    //       browser_network_requests。
    //
    // 配置说明:
    //   - 复用本机 /usr/bin/google-chrome，避免下载 ~150MB Chromium。
    //   - --headless: 默认无头；开发自测时可临时去掉或改为 --headed。
    //   - --isolated: 每个 MCP session 独立 context，避免跨任务 cookie/state 污染。
    //   - --no-sandbox: 容器/沙箱环境通常需要。
    //   - 如需限制可访问域名，追加 "--allowed-origins", "http://localhost:*;http://127.0.0.1:*"。
    //   - PLAYWRIGHT_BROWSERS_PATH=0 抑制自动下载 Chromium，强制走 executable-path。
    //
    "playwright": {
      "type": "local",
      "command": [
        "npx", "-y", "@playwright/mcp@latest",
        "--browser", "chrome",
        "--executable-path", "/usr/bin/google-chrome",
        "--headless",
        "--isolated",
        "--no-sandbox"
      ],
      "environment": {
        "PLAYWRIGHT_BROWSERS_PATH": "0"
      },
      "enabled": true
    }
  }
}
